# Temporal — local dev
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=filaxis-pdf-pipeline

# Temporal Cloud (uncomment and fill to use Temporal Cloud instead of local)
# TEMPORAL_HOST=<namespace>.<account-id>.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=<namespace>.<account-id>
# TEMPORAL_API_KEY=<your-api-key>
# TEMPORAL_TLS=true

# Anthropic (LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=sqlite+aiosqlite:///./filaxis.db

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=filaxis-reports

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
# PORT is set automatically by Railway — do not set manually in Railway
